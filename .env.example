# ============================================================
# Plastilonas Peruanas SAC — Variables de entorno
# Copie a .env.local en desarrollo y configure en Vercel para producción.
# El sitio funciona sin ninguna de estas variables (los formularios usan
# WhatsApp), pero el chatbot y el login de clientes las requieren.
# ============================================================

# --- Chatbot IA (Claude vía Vercel AI SDK) ---
# Sin esta clave, el widget de chat muestra el canal de WhatsApp.
ANTHROPIC_API_KEY=

# --- Autenticación de clientes (Auth.js v5) ---
# Genere el secreto con: npx auth secret
# Sin AUTH_SECRET, la página /login muestra "disponible próximamente".
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Callback: https://SU-DOMINIO/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Facebook OAuth — https://developers.facebook.com/apps
# Callback: https://SU-DOMINIO/api/auth/callback/facebook
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# X / Twitter OAuth 2.0 — https://developer.x.com/en/portal/dashboard
# Callback: https://SU-DOMINIO/api/auth/callback/twitter
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=
