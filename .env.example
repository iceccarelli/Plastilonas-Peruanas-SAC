# ============================================================
# Plastilonas Peruanas SAC — Variables de entorno
# Copie a .env.local en desarrollo y configure en Vercel para producción.
# El sitio funciona sin ninguna de estas variables (los formularios usan
# WhatsApp), pero el chatbot y el login de clientes las requieren.
# ============================================================

# --- Chatbot IA (Claude vía Vercel AI SDK) ---
# Sin esta clave, el widget de chat muestra el canal de WhatsApp.
ANTHROPIC_API_KEY=

# --- Autenticación de clientes (Auth.js v5) ---
# Genere el secreto con: npx auth secret
# Sin AUTH_SECRET, la página /login muestra "disponible próximamente".
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Callback: https://SU-DOMINIO/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Facebook OAuth — https://developers.facebook.com/apps
# Callback: https://SU-DOMINIO/api/auth/callback/facebook
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# X / Twitter OAuth 2.0 — https://developer.x.com/en/portal/dashboard
# Callback: https://SU-DOMINIO/api/auth/callback/twitter
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# --- Base de datos / persistencia (Supabase) ---
# Sin estas variables, el sitio público funciona igual; se deshabilitan
# los pedidos persistidos y el dashboard de pedidos.
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Pagos: Stripe (checkout hospedado, rail primario) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# URL pública del sitio para construir las URLs de retorno de Stripe.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Analitica y pixeles (marketing / anuncios) ---
# Sin estas variables NO se carga ningun script de terceros; el sitio funciona igual.
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GTM_ID=
# 'true' = muestra banner de consentimiento y no carga analitica hasta aceptar.
NEXT_PUBLIC_REQUIRE_CONSENT=true
# 'true' = registra cada evento en consola (util para verificar sin IDs).
NEXT_PUBLIC_ANALYTICS_DEBUG=false

# --- Automatizacion de leads (n8n) ---
# URL del webhook de n8n. SERVIDOR ONLY (sin NEXT_PUBLIC_): el navegador no la ve.
# Sin esta variable, /api/lead responde 200 y no reenvia — el lead sigue por WhatsApp.
N8N_WEBHOOK_URL=

# --- Notificaciones web push (OneSignal) ---
# App ID de OneSignal (publico, SDK de cliente). Sin el, no se carga nada.
NEXT_PUBLIC_ONESIGNAL_APP_ID=
